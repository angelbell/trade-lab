//@version=5
// =============================================================================
//  [GOLD 5M]  Exhaustion-Bounce -> recent Big-Down-Candle high  (long-only scalp)
//
//  ロジック（強い下落の"戻し"を取る逆張りスキャルプ。下げの中の一時反発狙い）:
//    枯れ足(arm) : (1) 直近 whtfBars 本の新安値を更新（下落が続いて新安値）
//                  (2) 直近 clusterK 本中 needWicks 本以上が長い下ヒゲ
//                      （下ヒゲ >= wickRatio×レンジ）= 下髭連発＝安値拒否
//                  (3) その足が陽線・終値がレンジの上 upClosePos 以上 = 反発の入り足
//    確認(entry) : 入り足の高値を後続足が「終値で」上抜く（confirmM 本以内）。
//                  途中でクラスター安値を割ったら無効（戻し失敗＝見送り）。確認足の終値で発注。
//    損切り      : クラスター安値の少し下（直近の押し安値）。
//    利確        : 直近の「大陰線」(陰線実体 >= bigBodyATR×ATR) の高値
//                  ＝下げを作った足の高値への戻り。全利確（トレールは下降再開に食われるので不採用）。
//
//  no-lookahead : 確定足の値のみ参照（終値での確認・歴史バー探索）。終値計算→次足で1本ぶんの誤差。
//  注意         : これは裁量スキャルプの"粗い機械化"。未検証・小サンプル。5M チャート・自分の
//                 フィードで要確認。スプレッド/スリッページは commission/slippage に各自設定。
//                 1%リスク上限・実DDは想定の1.5-2倍。スワップ未計上。
// =============================================================================
strategy("[GOLD 5M] Exhaustion-Bounce -> Big-Down-Candle High",
     overlay                 = true,
     initial_capital         = 10000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     calc_on_every_tick      = false,
     process_orders_on_close = false,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.0)

// ----- inputs ----------------------------------------------------------------
whtfBars   = input.int(240,  "New-low lookback (bars)",                 minval = 20)
clusterK   = input.int(5,    "Wick-cluster window (bars)",              minval = 2)
needWicks  = input.int(2,    "Min lower-wick bars in cluster",          minval = 1)
wickRatio  = input.float(0.5,"Lower-wick >= this x bar range",          step = 0.05, minval = 0.1, maxval = 1.0)
upClosePos = input.float(0.55,"Entry-bar close position in range (>=)", step = 0.05, minval = 0.0, maxval = 1.0)
confirmM   = input.int(6,    "Confirm window (bars to follow-through)", minval = 1)
bigBodyATR = input.float(1.5,"Big-down-candle body >= this x ATR",      step = 0.1,  minval = 0.5)
lookbkBig  = input.int(40,   "Lookback for the big-down-candle (bars)", minval = 1)
atrLen     = input.int(14,   "ATR length",                             minval = 1)
stopBuf    = input.float(0.3,"Stop buffer below cluster low (price)",   step = 0.1,  minval = 0.0)
minTgtATR  = input.float(2.0,"Min target distance (big-down-candle high >= this x ATR)", step = 0.5, minval = 0.0)
riskPct    = input.float(1.0,"Risk per trade (% equity)",              step = 0.25, minval = 0.0) / 100.0

atr  = ta.atr(atrLen)
rng  = high - low
lwr  = rng > 0 ? (math.min(open, close) - low) / rng : 0.0          // lower-wick ratio
nwick = math.sum(lwr >= wickRatio ? 1.0 : 0.0, clusterK)           // 下髭連発 count
clusterLow = ta.lowest(low, clusterK)
freshLow   = clusterLow <= ta.lowest(low, whtfBars)[clusterK]       // the CLUSTER low is a new low vs the window before it
upBar      = close > open and rng > 0 and (close - low) / rng >= upClosePos
isExhaust  = freshLow and nwick >= needWicks and upBar

// ----- arm / confirm state machine -------------------------------------------
var bool  armed   = false
var int   armBar  = na
var float armHigh = na
var float armLow  = na
var float armTgt  = na
var float curStop = na
var float curTgt  = na
flat = strategy.position_size == 0

// 1) resolve an existing arm FIRST (a bar can arm OR enter, not both)
if armed
    if bar_index - armBar > confirmM
        armed := false
    else if low < armLow
        armed := false                                             // cluster low broken -> reversal failed
    else if close > armHigh and flat and not na(armTgt) and (armTgt - close) >= minTgtATR * atr
        risk = close - (armLow - stopBuf)
        if risk > 0
            curStop := armLow - stopBuf
            curTgt  := armTgt
            strategy.entry("L", strategy.long, qty = (strategy.equity * riskPct) / risk)
        armed := false

// 2) arm a fresh exhaustion bar (only when flat & not already armed)
if isExhaust and not armed and flat
    float tgt = na
    for k = 1 to lookbkBig
        if (open[k] - close[k]) >= bigBodyATR * atr[k]              // most recent 大陰線
            tgt := high[k]
            break
    if not na(tgt)
        armed   := true
        armBar  := bar_index
        armHigh := high
        armLow  := clusterLow
        armTgt  := tgt

if strategy.position_size > 0
    strategy.exit("L-exit", "L", stop = curStop, limit = curTgt)

// ----- visuals ---------------------------------------------------------------
plotshape(isExhaust, "exhaustion bar", style = shape.triangleup, location = location.belowbar,
     color = color.new(color.aqua, 0), size = size.tiny)
plot(armed ? armTgt : na, "Target = big-down-candle high", color = color.new(color.lime, 0),
     style = plot.style_linebr, linewidth = 1)
plot(armed ? (armLow - stopBuf) : na, "Stop = below cluster low", color = color.new(color.red, 0),
     style = plot.style_linebr, linewidth = 1)
bgcolor(armed ? color.new(color.aqua, 92) : na, title = "armed (waiting follow-through)")
plotshape(strategy.position_size == 0 and armed and close > armHigh, "entry", style = shape.labelup,
     location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny)
