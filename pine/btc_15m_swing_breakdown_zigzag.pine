//@version=5
// =============================================================================
//  [BTC 15M]  Swing Breakdown -- Pattern B mirror (lower-high) -- ZigZag / RR4.5
//             + KAMA-falling gate + PDL new-low filter + RALLY-LIMIT entry.
//             15M chart, short-only. ロングレッグ（btc_15m_swing_breakout_zigzag）の鏡像。
//
//  ⚠️ ロングと非対称なのは意図的（測定結果）。BTC には上昇ドリフトがあるので、
//     ドリフトと逆向きのショートは「ハードルを上げる」側が正しい:
//       ゲート = 日足（遅い）。4時間足にすると弱気年の稼ぎは増えるが、強気相場の押し目を
//                全部ショートしに行くので平時に出血し、ブックは劣後する。
//       PDL   = ハード・フィルタ（前日安値割れ必須）。ロング側の「見送るな、小さく張れ」は
//                ショートでは逆効果（ソフト化するとブックが単調に悪化）。
//       RR    = 4.5（ここだけロングと同じ。台地 4.25-4.75 の中）。
//
//  ロジック（下方ブレイク、戻り売り指値執行）:
//    波の検出 : オンライン ZigZag（zzK*ATR 逆行で確定、リペイント無し）。
//    骨格     : H0(高)->L1(安=1波底)->H2(高) で H2<H0（lower high）。L1<80EMA（任意ゲート）。
//    レジーム : KAMA(14)が前バーまで【下向き】（既定=日足。ショートは遅いゲートが適合、
//               速い4hはダマシ戻りに食われる）。
//    構造位置 : ブレイク終値が【前日安値より下（新安値圏）のみ】エントリー（既定ハード。
//               下に昨日の買い支えが無い空中戦だけ取る。insideW>0でレンジ内も縮小玉可）。
//    トリガ   : H2 確定後、足が L1 を「終値で」下抜け＋ゲート/PDL条件で "武装"。
//    エントリ : 成行で飛び乗らず、ブレイク終値 e・損切 H2・risk=H2-e に対し
//               lim = e + frac*risk（既定 frac0.3）に売り指値。戻り（スクイーズ）が lim に
//               来たら約定。来る前に target へ走り抜けたら見送り（追わない）。
//    損切/利確: 損切=H2（価格固定）、利確=e-RR*risk（価格固定、既定RR4）。指値を上げるぶん
//               実効RRは膨らむ。サイズ: 1トレード=資金 riskPct%（risk=H2-lim）。
//
//  no-lookahead: KAMAゲート/PDL は [1]（前バー/前日の確定値）+ lookahead_off。
//  運用上の注意 : short-only・低頻度レッグ（年10数回）。ロングレッグより小玉推奨。
//                 スワップ（ショート保有コスト）は別途確認。15M チャートに適用。
// =============================================================================
strategy("[BTC 15M] Swing Breakdown (ZigZag) + rally-limit",
     overlay                 = true,
     initial_capital         = 10000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     calc_on_every_tick      = false,
     process_orders_on_close = false,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.03)

// ----- inputs ----------------------------------------------------------------
zzK      = input.float(2.0,  "ZigZag reversal (ATR)", step = 0.25, minval = 0.5)
atrLen   = input.int(14,     "ATR length", minval = 1)
trendLen = input.int(80,     "Trend EMA (gate)", minval = 1)
useGate  = input.bool(true,  "Require wave-1 low below trend EMA")
rr       = input.float(4.5,  "Reward : Risk (fixed target level)", step = 0.5, minval = 0.5)
boWindow = input.int(20,     "Breakdown window (bars after wave-2 high)", minval = 1)
riskPct  = input.float(1.0,  "Risk per trade (% equity)", step = 0.25, minval = 0.0) / 100.0
pbFrac   = input.float(0.30, "Rally-limit depth (entry = e + frac*risk)", step = 0.05, minval = 0.0, maxval = 0.95)
fillWin  = input.int(200,    "Rally-limit fill window (bars; cancel if unfilled)", minval = 1)
useKama  = input.bool(true,  "KAMA-FALLING regime gate")
kamaTf   = input.timeframe("D", "KAMA gate timeframe (D = validated for shorts)")
kamaLen  = input.int(14,     "KAMA length", minval = 2)
usePdl   = input.bool(true,  "PDL filter (only breaks below prior-day low)")
pdlInW   = input.float(0.0,  "Inside-range size multiplier (0 = skip, validated default)", step = 0.25, minval = 0.0, maxval = 1.0)
showZZ   = input.bool(true,  "ZigZag: draw the swing line", group = "ZigZag drawing")
zzCol    = input.color(color.new(color.teal, 0), "ZigZag color", group = "ZigZag drawing")
zzW      = input.int(2,      "ZigZag width", minval = 1, group = "ZigZag drawing")

atr   = ta.atr(atrLen)
ema80 = ta.ema(close, trendLen)
flat  = strategy.position_size == 0

// Kaufman Adaptive MA (KAMA) -- ER-modulated smoothing (fast=2, slow=30).
f_kama(src, len) =>
    mom = math.abs(src - src[len])
    vol = math.sum(math.abs(src - src[1]), len)
    er  = vol != 0 ? mom / vol : 0.0
    sc  = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float k = na
    k := na(k[1]) ? src : k[1] + sc * (src - k[1])
    k

// KAMA(kamaLen)-FALLING gate on kamaTf (prior completed bar; no repaint / no lookahead).
dKama1 = request.security(syminfo.tickerid, kamaTf, f_kama(close, kamaLen)[1], lookahead = barmerge.lookahead_off)
dKama2 = request.security(syminfo.tickerid, kamaTf, f_kama(close, kamaLen)[2], lookahead = barmerge.lookahead_off)
kamaDn = dKama1 < dKama2
kamaOk = (not useKama) or kamaDn

// prior-day low (prior COMPLETED day; no repaint / no lookahead)
pdl = request.security(syminfo.tickerid, "1D", low[1], lookahead = barmerge.lookahead_off)

// ----- online ZigZag (ATR-threshold reversal) --------------------------------
var int   zzDir = 1
var float zzExt = na
var int   zzExtBar   = na  // bar_index of the running extreme (for ZigZag drawing)
var int   zzPrevBar  = na  // last confirmed pivot: bar
var float zzPrevPrice = na // last confirmed pivot: price
if na(zzExt)
    zzExt := high
if na(zzExtBar)
    zzExtBar := bar_index

var float swLow      = na   // L1 (wave-1 low = breakdown line)
var float swHigh     = na   // H2 (lower high = stop)
var float swHighPrev = na   // H0

var bool  armed  = false
var float armL1  = na
var float armH2  = na
var int   armBar = na

thr = zzK * atr

if zzDir <= 0
    if low < zzExt
        zzExt := low
    else if high - zzExt >= thr
        swLow := zzExt
        if showZZ
            if not na(zzPrevBar)
                line.new(zzPrevBar, zzPrevPrice, zzExtBar, swLow, xloc = xloc.bar_index, color = zzCol, width = zzW)
            zzPrevBar   := zzExtBar
            zzPrevPrice := swLow
        zzDir := 1
        zzExt := high
if zzDir >= 0
    if high > zzExt
        zzExt := high
    else if zzExt - low >= thr
        swHighPrev := swHigh
        swHigh     := zzExt
        if showZZ
            if not na(zzPrevBar)
                line.new(zzPrevBar, zzPrevPrice, zzExtBar, swHigh, xloc = xloc.bar_index, color = zzCol, width = zzW)
            zzPrevBar   := zzExtBar
            zzPrevPrice := swHigh
        zzDir      := -1
        zzExt      := low
        okStruct = not na(swLow) and not na(swHighPrev) and swHigh < swHighPrev and swLow < swHighPrev
        okGate   = (not useGate) or (not na(ema80) and swLow < ema80)
        if okStruct and okGate
            armed  := true
            armL1  := swLow
            armH2  := swHigh
            armBar := bar_index

// track the bar of the running extreme (for ZigZag drawing; updated after the swing block)
if not na(zzExt[1]) and zzExt != zzExt[1]
    zzExtBar := bar_index

if armed and (bar_index - armBar) > boWindow
    armed := false

// ----- rally-limit state machine ----------------------------------------------
var bool  pend    = false
var float pLim    = na
var float pStop   = na
var float pTgt    = na
var float pU      = na       // realized risk = stop - lim (sizing unit)
var float pW      = na       // size weight: 1.0 below PDL (new-low air), pdlInW inside
var int   pBar    = na
var float curStop = na
var float curTgt  = na

// place a rally limit on a confirmed breakdown (do not chase at market)
if armed and flat and not pend and bar_index > armBar and close < armL1 and kamaOk
    e    = close
    risk = armH2 - e
    lim  = e + pbFrac * risk
    w    = (not usePdl) or (not na(pdl) and e < pdl) ? 1.0 : pdlInW
    if risk > 0 and lim < armH2 and w > 0
        pLim  := lim
        pStop := armH2
        pTgt  := e - rr * risk
        pU    := armH2 - lim
        pW    := w
        pBar  := bar_index
        pend  := true
    armed := false

// while waiting: keep the limit live; cancel if price ran to target first or expired
if pend and flat
    // BTC 最小ロット 0.01 → 小数第2位に切り上げ（リスク許容5%内なので取りこぼしを避け最小0.01で建てる）
    qty = math.ceil((strategy.equity * riskPct * pW) / pU * 100) / 100
    if qty >= 0.01
        strategy.entry("S", strategy.short, qty = qty, limit = pLim)
    if low <= pTgt
        strategy.cancel("S")
        pend := false
    else if bar_index - pBar >= fillWin
        strategy.cancel("S")
        pend := false

// on fill: lock the exit levels
if strategy.position_size < 0 and pend
    pend    := false
    curStop := pStop
    curTgt  := pTgt

if strategy.position_size < 0
    strategy.exit("S-exit", "S", stop = curStop, limit = curTgt)

// ----- plots -----------------------------------------------------------------
bgcolor(useKama and not kamaDn ? color.new(color.teal, 90) : na, title = "KAMA rising (shorts gated off)")
plot(ema80, "Trend EMA", color = color.new(color.blue, 0), linewidth = 2)
plot(armed ? armL1 : na, "Armed L1 (breakdown line)", color = color.new(color.orange, 0),
     style = plot.style_linebr, linewidth = 1)
plot(armed ? armH2 : na, "Armed H2 (stop)", color = color.new(color.red, 0),
     style = plot.style_linebr, linewidth = 1)
plot(pend ? pLim : na, "Rally limit", color = color.new(color.aqua, 0),
     style = plot.style_linebr, linewidth = 1)
plot(usePdl ? pdl : na, "Prior-day low (PDL)", color = color.new(color.gray, 30),
     style = plot.style_steplinebr, linewidth = 1)
brkNow = armed and flat and not pend and bar_index > armBar and close < armL1 and kamaOk
plotshape(brkNow and close < pdl, title = "Breakdown below PDL (take)",
     style = shape.triangledown, location = location.abovebar, color = color.red, size = size.tiny)
plotshape(brkNow and not (close < pdl), title = "Breakdown inside range (skip/reduced)",
     style = shape.triangledown, location = location.abovebar, color = color.yellow, size = size.tiny)
