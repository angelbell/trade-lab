//@version=5
// =============================================================================
//  [15M] Swing Breakdown Detector (ZigZag) -- indicator (not a strategy).
//  デイスキャル用の下方ブレイク（ショート）検出器。swing_breakout_detector_15m の鏡像。
//  BTC 15M 用（ゴールドのショート側は対象外）。15M チャートに適用。
//
//  何をするか（2段階）:
//    1) 構え(ARMED): オンライン ZigZag（zzK*ATR 逆行で確定、リペイント無し）が
//       H0(高)->L1(安)->H2(高) かつ H2<H0（lower high）を確定し、L1<トレンドEMA（任意）なら
//       「構え」。L1=ブレイク線（橙）と H2=損切り線（赤）をチャートに描く。
//       boWindow 本以内にブレイクしなければ構え解除。
//    2) 確定ブレイク(GO): 足が L1 を「終値で」下抜け、かつ有効な全ゲートがONなら GO シグナル
//       （赤▼＋ラベル: エントリ/損切/利確/戻り指値の価格）。ゲートOFF中のブレイクは
//       灰×で表示のみ（見送りの記録）。ブレイクは構えを消費する（GO でも見送りでも解除）。
//
//  ゲート（既定 = BTC 15M ショートの採用形）:
//    KAMA : KAMA(14) が前バーまで【下向き】のときのみ GO（既定=日足。ショートは遅い
//           ゲートが適合。240 に落とすと本数は増えるがダマシ戻りに食われやすい）。
//    PDL  : ブレイク終値が【前日安値より下（新安値圏）のみ】GO（既定ハード。下に昨日の
//           買い支えが無い空中戦だけ取る。KAMAはOKだがレンジ内、のブレイクは黄▼で
//           表示のみ＝縮小玉の裁量余地）。
//
//  発注の目安（ラベルの数字）:
//    エントリ e = ブレイク足の終値。損切 = H2。利確 = e - RR*(H2-e)。
//    戻り指値 lim = e + pbFrac*(H2-e)（既定 frac0.3。lim に売り指値を置き、刺さる前に
//    利確水準へ走り抜けたら見送り＝追わない）。サイズは各自 口座リスク%/(H2-lim) で計算。
//
//  アラート: 「アラート作成 -> 条件=このインジ」で
//    (1) Setup armed  (2) GO breakdown  の2種。足の確定で評価（"Once per bar close"）。
//    動的な価格入りメッセージは「Any alert() function call」を選ぶ（GO 時に価格入りで発報）。
//
//  no-lookahead / no-repaint: KAMA・PDL は [1]（前バー/前日の確定値）+ lookahead_off。
//  ZigZag はしきい値到達で確定（過去の描き直し無し）。トリガは確定足の終値のみ。
//  注意: 本検出器はコスト・サイズ・約定を扱わない（見る/鳴らす専用）。低頻度レッグ
//  （年10数回）・ショート保有はスワップ確認。検証・成績は strategy 版
//  （btc_15m_swing_breakdown_zigzag）で行うこと。
// =============================================================================
indicator("[15M] Swing Breakdown Detector (ZigZag)", overlay = true,
     max_labels_count = 500, max_lines_count = 500)

// ----- inputs ----------------------------------------------------------------
zzK      = input.float(2.0, "ZigZag reversal (ATR)",  step = 0.25, minval = 0.5)
atrLen   = input.int(14,    "ATR length",             minval = 1)
trendLen = input.int(80,    "Trend EMA (gate)",       minval = 1)
useGate  = input.bool(true, "Require wave-1 low below trend EMA")
rr       = input.float(4.0, "Reward : Risk (target display)", step = 0.5, minval = 0.5)
boWindow = input.int(20,    "Breakdown window (bars after wave-2 high)", minval = 1)
pbFrac   = input.float(0.30, "Rally-limit depth display (0 = market entry)", step = 0.05, minval = 0.0, maxval = 0.95)

grpG     = "Regime gates (preset: BTC short = KAMA-falling + PDL)"
useKama  = input.bool(true, "KAMA-FALLING regime gate", group = grpG)
kamaTf   = input.timeframe("D", "KAMA gate timeframe (D = validated for shorts)", group = grpG)
kamaLen  = input.int(14,    "KAMA length", minval = 2, group = grpG)
usePdl   = input.bool(true, "PDL filter (GO only on breaks below the prior-day low)", group = grpG)

grpD     = "Drawing"
showZZ   = input.bool(true, "ZigZag: draw the swing line", group = grpD)
zzCol    = input.color(color.new(color.teal, 0), "ZigZag color", group = grpD)
zzW      = input.int(2,     "ZigZag width", minval = 1, group = grpD)
showTbl  = input.bool(true, "Show the gate/state table", group = grpD)
markOff  = input.bool(true, "Mark gated-off breaks (gray x / yellow = inside range)", group = grpD)

atr   = ta.atr(atrLen)
ema80 = ta.ema(close, trendLen)

// Kaufman Adaptive MA (KAMA) -- ER-modulated smoothing (fast=2, slow=30).
f_kama(src, len) =>
    mom = math.abs(src - src[len])
    vol = math.sum(math.abs(src - src[1]), len)
    er  = vol != 0 ? mom / vol : 0.0
    sc  = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float k = na
    k := na(k[1]) ? src : k[1] + sc * (src - k[1])
    k

// KAMA(kamaLen)-FALLING gate on kamaTf (prior completed bar; no repaint / no lookahead).
dKama1 = request.security(syminfo.tickerid, kamaTf, f_kama(close, kamaLen)[1], lookahead = barmerge.lookahead_off)
dKama2 = request.security(syminfo.tickerid, kamaTf, f_kama(close, kamaLen)[2], lookahead = barmerge.lookahead_off)
kamaDn = dKama1 < dKama2
kamaOk = (not useKama) or kamaDn

// prior-day low (prior COMPLETED day; no repaint / no lookahead)
pdl = request.security(syminfo.tickerid, "1D", low[1], lookahead = barmerge.lookahead_off)

// ----- online ZigZag (ATR-threshold reversal) --------------------------------
var int   zzDir = 1
var float zzExt = na
var int   zzExtBar    = na  // bar_index of the running extreme (for ZigZag drawing)
var int   zzPrevBar   = na  // last confirmed pivot: bar
var float zzPrevPrice = na  // last confirmed pivot: price
if na(zzExt)
    zzExt := high
if na(zzExtBar)
    zzExtBar := bar_index

var float swLow      = na   // L1 (wave-1 low = breakdown line)
var float swHigh     = na   // H2 (lower high = stop)
var float swHighPrev = na   // H0

var bool  armed  = false
var float armL1  = na
var float armH2  = na
var int   armBar = na

thr = zzK * atr

if zzDir <= 0
    if low < zzExt
        zzExt := low
    else if high - zzExt >= thr
        swLow := zzExt
        if showZZ
            if not na(zzPrevBar)
                line.new(zzPrevBar, zzPrevPrice, zzExtBar, swLow, xloc = xloc.bar_index, color = zzCol, width = zzW)
            zzPrevBar   := zzExtBar
            zzPrevPrice := swLow
        zzDir := 1
        zzExt := high
if zzDir >= 0
    if high > zzExt
        zzExt := high
    else if zzExt - low >= thr
        swHighPrev := swHigh
        swHigh     := zzExt
        if showZZ
            if not na(zzPrevBar)
                line.new(zzPrevBar, zzPrevPrice, zzExtBar, swHigh, xloc = xloc.bar_index, color = zzCol, width = zzW)
            zzPrevBar   := zzExtBar
            zzPrevPrice := swHigh
        zzDir := -1
        zzExt := low
        okStruct = not na(swLow) and not na(swHighPrev) and swHigh < swHighPrev and swLow < swHighPrev
        okGate   = (not useGate) or (not na(ema80) and swLow < ema80)
        if okStruct and okGate
            armed  := true
            armL1  := swLow
            armH2  := swHigh
            armBar := bar_index

// track the bar of the running extreme (for ZigZag drawing; updated after the swing block)
if not na(zzExt[1]) and zzExt != zzExt[1]
    zzExtBar := bar_index

// arm expiry + arm-event flag (for the alert)
var bool armedNew = false
armedNew := armed and not armed[1]
if armed and (bar_index - armBar) > boWindow
    armed := false

// ----- break detection (confirmed close below L1; break consumes the arm) -----
pdlOk   = (not usePdl) or (not na(pdl) and close < pdl)
gatesOk = kamaOk and pdlOk
brk     = armed and bar_index > armBar and close < armL1
sigGo   = brk and gatesOk
sigIn   = brk and kamaOk and not pdlOk   // KAMA OK but inside range (reduced-size discretion)
sigOff  = brk and not kamaOk

if brk
    e    = close
    risk = armH2 - e
    if sigGo and risk > 0
        lim  = e + pbFrac * risk
        tgt  = e - rr * risk
        txt  = "GO SHORT  e=" + str.tostring(e, format.mintick) + "\nSL=" + str.tostring(armH2, format.mintick) + "  TP=" + str.tostring(tgt, format.mintick) + (pbFrac > 0.0 ? "\nlim=" + str.tostring(lim, format.mintick) : "")
        label.new(bar_index, high, txt, style = label.style_label_down, color = color.new(color.red, 15), textcolor = color.white, size = size.small)
        if barstate.isconfirmed
            alert("[15M BD] " + syminfo.ticker + " GO SHORT: e=" + str.tostring(e, format.mintick) + " SL=" + str.tostring(armH2, format.mintick) + " TP=" + str.tostring(tgt, format.mintick) + (pbFrac > 0.0 ? " lim=" + str.tostring(lim, format.mintick) : ""), alert.freq_once_per_bar_close)
    armed := false

// ----- plots -----------------------------------------------------------------
plot(ema80, "Trend EMA", color = color.new(color.blue, 0), linewidth = 2)
plot(armed ? armL1 : na, "Armed L1 (breakdown line)", color = color.new(color.orange, 0),
     style = plot.style_linebr, linewidth = 1)
plot(armed ? armH2 : na, "Armed H2 (stop)", color = color.new(color.red, 0),
     style = plot.style_linebr, linewidth = 1)
plot(usePdl ? pdl : na, "Prior-day low (PDL)", color = color.new(color.gray, 30),
     style = plot.style_steplinebr, linewidth = 1)
bgcolor(useKama and not kamaDn ? color.new(color.teal, 90) : na, title = "KAMA rising (shorts gated off)")

plotshape(sigGo, title = "GO breakdown", style = shape.triangledown, location = location.abovebar,
     color = color.red, size = size.small)
plotshape(markOff and sigIn, title = "Break inside range (reduced/skip)", style = shape.triangledown,
     location = location.abovebar, color = color.yellow, size = size.tiny)
plotshape(markOff and sigOff, title = "Gated-off break (KAMA rising)", style = shape.xcross,
     location = location.abovebar, color = color.new(color.gray, 20), size = size.tiny)
plotshape(armedNew, title = "Setup armed", style = shape.circle, location = location.abovebar,
     color = color.new(color.orange, 30), size = size.tiny)

// ----- gate/state table --------------------------------------------------------
var table tbl = table.new(position.top_right, 2, 4, border_width = 1)
if showTbl and barstate.islast
    okCol  = color.new(color.green, 70)
    ngCol  = color.new(color.red,   70)
    naCol  = color.new(color.gray,  80)
    table.cell(tbl, 0, 0, "構え",  bgcolor = armed ? okCol : naCol, text_color = color.white)
    table.cell(tbl, 1, 0, armed ? "L1=" + str.tostring(armL1, format.mintick) + " H2=" + str.tostring(armH2, format.mintick) : "--", bgcolor = armed ? okCol : naCol, text_color = color.white)
    table.cell(tbl, 0, 1, "KAMA",  bgcolor = not useKama ? naCol : kamaDn ? okCol : ngCol, text_color = color.white)
    table.cell(tbl, 1, 1, not useKama ? "OFF" : kamaDn ? "下向き" : "上向き", bgcolor = not useKama ? naCol : kamaDn ? okCol : ngCol, text_color = color.white)
    table.cell(tbl, 0, 2, "PDL",   bgcolor = not usePdl ? naCol : close < pdl ? okCol : color.new(color.yellow, 70), text_color = color.white)
    table.cell(tbl, 1, 2, not usePdl ? "OFF" : close < pdl ? "下（新安値圏）" : "レンジ内（見送り/減量）", bgcolor = not usePdl ? naCol : close < pdl ? okCol : color.new(color.yellow, 70), text_color = color.white)
    table.cell(tbl, 0, 3, "総合",  bgcolor = gatesOk ? okCol : ngCol, text_color = color.white)
    table.cell(tbl, 1, 3, gatesOk ? "GO可" : "見送り", bgcolor = gatesOk ? okCol : ngCol, text_color = color.white)

// ----- alerts ------------------------------------------------------------------
alertcondition(armedNew, "Setup armed",  "[15M BD] setup armed: lower-high confirmed, watching the L1 breakdown line")
alertcondition(sigGo,    "GO breakdown", "[15M BD] confirmed breakdown with all gates ON (below PDL)")
