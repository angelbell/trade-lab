//@version=5
// =============================================================================
//  [GOLD 4H]  EMA Pullback Continuation (20/80, RR 1:3) -- CONFIRMED-CLOSE entry.
//             4H chart, long-only.
//
//  ロジック:
//    トレンド : 80EMA の傾き（slopeK 本前比）。上向き=ロング、下向き=ショート、横=見送り。
//    押し目   : ロング地合いで価格が 20EMA を終値で下抜け＝押し目。安値の極値を記録。
//    エントリ : 押し目後、足が 20EMA を「終値で」抜け返して確定→次足始値で約定（だましヒゲ回避）。
//    損切り   : 押し目の極値（狭ければ ATR で床固め）。利確: 損切り幅 × RR（既定 1:3）。
//    サイズ   : 1トレード = 資金の riskPct%。
//
//  no-lookahead: 確認足の終値→次足始値で約定。
//  運用上の注意 : 1%リスク上限・実DDは1.5-2倍想定。スワップ未計上。4H チャートに適用すること。
// =============================================================================
strategy("[GOLD 4H] EMA Pullback",
     overlay            = true,
     initial_capital    = 10000,
     default_qty_type   = strategy.fixed,
     default_qty_value  = 1,
     calc_on_every_tick = false,
     process_orders_on_close = false,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.02)

// ----- inputs ----------------------------------------------------------------
emaFastLen = input.int(21,  "Fast MA (pullback)", minval=1)
emaSlowLen = input.int(80,  "Slow MA (trend)",    minval=1)
fastType   = input.string("EMA", "Fast MA type",  options=["EMA", "SMA"])
trendType  = input.string("EMA", "Trend MA type", options=["EMA", "SMA"])
slopeK     = input.int(6,   "Trend slope lookback (bars)", minval=1)
atrLen     = input.int(14,  "ATR length",          minval=1)
rr         = input.float(3.0, "Reward : Risk",     step=0.5, minval=0.5)
minStopATR = input.float(0.5, "Min stop distance (ATR)", step=0.1, minval=0.0)
riskPct    = input.float(1.0, "Risk per trade (% equity)", step=0.25, minval=0.0) / 100.0
useLongs   = input.bool(true,  "Trade longs")
useShorts  = input.bool(false, "Trade shorts")   // GOLD: longs are the robust side

// ----- indicators ------------------------------------------------------------
// EMA/SMA を入力で切替（両方計算して選択 = ta.* を毎足評価して安全）
f_ma(src, length, isSMA) =>
    isSMA ? ta.sma(src, length) : ta.ema(src, length)

ef  = f_ma(close, emaFastLen, fastType  == "SMA")   // 押し目/エントリー基準（既定 21EMA）
es  = f_ma(close, emaSlowLen, trendType == "SMA")   // トレンド基準（既定 80EMA）
atr = ta.atr(atrLen)

upTrend = es > es[slopeK]                 // 80EMA が slopeK 本で上向き
dnTrend = es < es[slopeK]                 // 同 下向き

flat = strategy.position_size == 0

// ----- pullback state machine ------------------------------------------------
var int   lState = 0     // 1 = ロング押し目進行中（終値での奪還確定を待つ）
var float lExt   = na    // 押し目中の最安値
var float lStop  = na
var float lTgt   = na
var int   sState = 0
var float sExt   = na     // 戻り中の最高値
var float sStop  = na
var float sTgt   = na

// トレンドが消えたら押し目状態をリセット
if not upTrend
    lState := 0
    lExt   := na
if not dnTrend
    sState := 0
    sExt   := na

// ---- LONG -------------------------------------------------------------------
if upTrend
    if close < ef
        // 押し目継続: 極値を更新
        lState := 1
        lExt   := na(lExt) ? low : math.min(lExt, low)
    else if lState == 1 and flat and useLongs
        // ★確認: 足が 20EMA を終値で抜け返した -> 次足始値でエントリー
        sR = math.min(lExt, low)
        sP = (close - sR) < minStopATR * atr ? close - minStopATR * atr : sR
        r  = close - sP
        if r > 0
            lStop := sP
            lTgt  := close + rr * r
            qty = math.ceil((strategy.equity * riskPct) / r * 100) / 100  // 0.01ロット刻みに切り上げ
            strategy.entry("L", strategy.long, qty = qty)
        lState := 0
        lExt   := na

if strategy.position_size > 0
    strategy.exit("L-exit", "L", stop = lStop, limit = lTgt)

// ---- SHORT (mirror) ---------------------------------------------------------
if dnTrend
    if close > ef
        sState := 1
        sExt   := na(sExt) ? high : math.max(sExt, high)
    else if sState == 1 and flat and useShorts
        sR = math.max(sExt, high)
        sP = (sR - close) < minStopATR * atr ? close + minStopATR * atr : sR
        r  = sP - close
        if r > 0
            sStop := sP
            sTgt  := close - rr * r
            qty = math.ceil((strategy.equity * riskPct) / r * 100) / 100  // 0.01ロット刻みに切り上げ
            strategy.entry("S", strategy.short, qty = qty)
        sState := 0
        sExt   := na

if strategy.position_size < 0
    strategy.exit("S-exit", "S", stop = sStop, limit = sTgt)

// ----- plots -----------------------------------------------------------------
plot(ef, "Fast MA",  color = color.new(color.orange, 0), linewidth = 1)
plot(es, "Trend MA", color = color.new(color.blue,   0), linewidth = 2)
bgcolor(upTrend ? color.new(color.green, 92) : dnTrend ? color.new(color.red, 92) : na,
     title = "Trend regime")
