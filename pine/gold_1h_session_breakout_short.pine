//@version=5
// gold_1h_orb_short_downtrend.pine  —  H17-S
// ============================================================================
// ORB SHORT-ONLY (Asian-range -> London DOWN-break continuation, ride to close).
// 1H (or 15M) XAUUSD chart.  DOUBLE-GATED:
//   (1) 1H trend gate  : prior completed 1H close < 1H EMA80
//   (2) Daily DOWNtrend: prior completed daily close < daily SMA80 AND SMA80 falling (~10d)
// Rationale: gold's edge is the sharp, deep London DOWN-move; it pays only in a
// confirmed daily downtrend, so the long side is dropped (dilutive beta).
//
//  ROLE = SEE / ALERT / FORWARD-TEST.  (Mechanized from research/scalp_lab.py
//  --dir short --daily-sma 80 --daily-slope-k 10; validation lives in docs/.)
//  運用上の注意 : DOWNTREND-ONLY なので強気相場では発火せず休眠・低頻度。サイズは小さく、
//                 実弾前に forward-test すること。
// ============================================================================
strategy("[GOLD 1H] Session Breakout (Short)", overlay=true,
     default_qty_type=strategy.fixed, default_qty_value=1,
     initial_capital=10000, pyramiding=0,
     commission_type=strategy.commission.cash_per_order, commission_value=0,
     calc_on_every_tick=false, process_orders_on_close=false)

// ---- inputs ----------------------------------------------------------------
tz        = input.string("UTC", "Session timezone (match your Vantage server clock)",
             tooltip="Python uses the broker-server timestamps literally as the clock. " +
                     "If your TV feed is in a different tz, set it here so the hour windows " +
                     "and the day boundary line up with the Python validation.")
asiaStart = input.int(0,  "Asian range START hour", minval=0, maxval=23)
asiaEnd   = input.int(7,  "Asian range END hour",   minval=1, maxval=24)
boStart   = input.int(7,  "Breakout START hour",    minval=0, maxval=23)
boEnd     = input.int(11, "Breakout END hour",      minval=1, maxval=24)
exitHour  = input.int(20, "Force-flat hour (session tz)", minval=0, maxval=23)
htfTf     = input.timeframe("60", "1H trend-gate timeframe")
emaLen    = input.int(80, "1H trend-gate EMA length", minval=5)
dSmaLen   = input.int(80, "Daily SMA length", minval=10, tooltip="80 = balanced default.")
dSlopeK   = input.int(10, "Daily SMA slope lookback (days)", minval=1)
slBufAtr  = input.float(0.0, "SL buffer (ATR mult; 0 = exact opposite range edge)", step=0.1)
useDaily  = input.bool(true, "Require daily DOWNtrend gate", group="Debug")
use1H     = input.bool(true, "Require 1H downtrend gate",    group="Debug")
showDiag  = input.bool(true, "Show diagnostic table",        group="Debug")

// ---- 1H trend gate, no-lookahead (prior completed 1H bar) ------------------
htfClose = request.security(syminfo.tickerid, htfTf, close[1],                 barmerge.gaps_off, barmerge.lookahead_on)
htfEma   = request.security(syminfo.tickerid, htfTf, ta.ema(close, emaLen)[1], barmerge.gaps_off, barmerge.lookahead_on)
gate1Hok = not na(htfClose) and not na(htfEma)
short1H  = use1H ? (gate1Hok and htfClose < htfEma) : true

// ---- daily DOWNtrend gate, no-lookahead (prior completed daily bar) --------
// below SMA AND SMA falling over dSlopeK days. All on the prior COMPLETED daily bar.
dBelowExpr   = close[1] < ta.sma(close, dSmaLen)[1]
dFallingExpr = ta.sma(close, dSmaLen)[1] < ta.sma(close, dSmaLen)[1 + dSlopeK]
dBelow   = request.security(syminfo.tickerid, "D", dBelowExpr,   barmerge.gaps_off, barmerge.lookahead_on)
dFalling = request.security(syminfo.tickerid, "D", dFallingExpr, barmerge.gaps_off, barmerge.lookahead_on)
gateDok  = not na(dBelow) and not na(dFalling)
shortDay = useDaily ? (gateDok and dBelow and dFalling) : true

shortRegime = short1H and shortDay

// ---- session helpers (hour-based, matches Python minute>=h*60 logic) --------
h      = hour(time, tz)
inAsia = h >= asiaStart and h < asiaEnd
inBO   = h >= boStart   and h < boEnd
dom    = dayofmonth(time, tz)
newDay = dom != dom[1]

// ---- Asian range (accumulate during Asian window, then FROZEN) -------------
var float asiaHi = na
var float asiaLo = na
var bool  entered = false
if newDay
    asiaHi  := na
    asiaLo  := na
    entered := false
// GLITCH GUARD (1H feed has a spike bar the 15M feed lacks -> identical code still
// drifted). Reference a STABLE SMA20 (a single bad bar barely moves it), so even a
// fully-corrupted OHLC bar is rejected. A real gold bar is always within +-50% of SMA20.
refPx = ta.sma(close, 20)
okBar = na(refPx) or (high < refPx * 1.5 and low > refPx * 0.5 and high >= low)
if inAsia and okBar
    asiaHi := na(asiaHi) ? high : math.max(asiaHi, high)
    asiaLo := na(asiaLo) ? low  : math.min(asiaLo, low)

slBuf = slBufAtr * ta.atr(14)

// ---- entry: first BO-window CLOSE below the frozen range, in a DOWNtrend ----
rangeReady = not na(asiaHi) and not na(asiaLo)
canEnter   = inBO and rangeReady and not entered and strategy.position_size == 0
shortBreak = canEnter and close < asiaLo and shortRegime

if shortBreak
    strategy.entry("S", strategy.short)
    entered := true

// ---- stop: opposite range edge (intrabar); NO take-profit (ride to close) --
if strategy.position_size < 0
    strategy.exit("S-sl", from_entry="S", stop=asiaHi + slBuf)

// ---- forced flat at the session-close hour ---------------------------------
if hour(time, tz) >= exitHour and strategy.position_size != 0
    strategy.close_all(comment="eod")

// ---- Asia range lines (same plot()+linebr method as the working 15M H17) -----
// (box.new floated above price when a day's asiaEnded was missed and the box kept
// extending right; the held-var plot used by the 15M version displays correctly.)
plot(rangeReady ? asiaHi : na, "Asia High", color.new(color.teal, 0), style=plot.style_linebr)
plot(rangeReady ? asiaLo : na, "Asia Low",  color.new(color.teal, 0), style=plot.style_linebr)
bgcolor(shortRegime ? color.new(color.red, 90) : na, title="short-ok regime (1H<EMA & daily downtrend)")
plotshape(shortBreak, "Short break", shape.triangledown, location.abovebar, color.red, size=size.tiny)

if shortBreak
    alert("Gold ORB short break (1H + daily downtrend)", alert.freq_once_per_bar_close)

// ---- diagnostics -----------------------------------------------------------
var int nBO = 0
var int nS = 0
nBO := nBO + (inBO ? 1 : 0)
nS  := nS  + (shortBreak ? 1 : 0)

dgCell(t, col, row, txt, bg) =>
    table.cell(t, col, row, txt, text_size=size.small, text_color=color.white, bgcolor=bg)

var table dg = table.new(position.top_right, 2, 8, frame_color=color.gray, frame_width=1)
if showDiag and barstate.islast
    okc = color.new(color.teal, 0)
    bad = color.new(color.red, 0)
    dgCell(dg, 0, 0, "Chart TF",      color.new(color.blue, 0))
    dgCell(dg, 1, 0, timeframe.period, (timeframe.period == "60" or timeframe.period == "15") ? okc : bad)
    dgCell(dg, 0, 1, "BO bars seen",  color.new(color.blue, 0))
    dgCell(dg, 1, 1, str.tostring(nBO), nBO > 0 ? okc : bad)
    dgCell(dg, 0, 2, "Range ready",   color.new(color.blue, 0))
    dgCell(dg, 1, 2, str.tostring(rangeReady), rangeReady ? okc : bad)
    dgCell(dg, 0, 3, "1H gate ok",    color.new(color.blue, 0))
    dgCell(dg, 1, 3, str.tostring(gate1Hok), gate1Hok ? okc : bad)
    dgCell(dg, 0, 4, "Daily gate ok", color.new(color.blue, 0))
    dgCell(dg, 1, 4, str.tostring(gateDok), gateDok ? okc : bad)
    dgCell(dg, 0, 5, "Short regime",  color.new(color.blue, 0))
    dgCell(dg, 1, 5, shortRegime ? "YES" : "no", shortRegime ? okc : color.new(color.gray, 0))
    dgCell(dg, 0, 6, "Short entries", color.new(color.blue, 0))
    dgCell(dg, 1, 6, str.tostring(nS), nS > 0 ? okc : bad)
    dgCell(dg, 0, 7, "Closed trades", color.new(color.blue, 0))
    dgCell(dg, 1, 7, str.tostring(strategy.closedtrades), strategy.closedtrades > 0 ? okc : bad)
