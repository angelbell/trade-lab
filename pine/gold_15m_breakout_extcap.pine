//@version=5
// =============================================================================
//  [GOLD 15M]  Breakout Wave -- Pattern B (3rd-wave) -- ZigZag / RR4 + daily gate
//              + extension-cap.  15M chart, long-only.
//
//  ロジック（手法B = 第3波ブレイク）:
//    波の検出 : オンライン ZigZag（zzK*ATR 逆行で確定、リペイント無し）。
//    骨格     : L0(安)->H1(高=1波天井)->L2(安) で L2>L0（higher low）。H1>80EMA（任意ゲート）。
//    エントリ : L2 確定後、足が H1 を「終値で」上抜け＋日足ゲートON＋extension<=cap なら発注（次足始値）。
//    損切り   : L2（2波安値）。利確: 損切り幅 × RR（既定 1:4）。サイズ: 1トレード = 資金の riskPct%。
//    日足ゲート: 前日確定 close > 上向き日足SMA のときだけ。extension-cap: 前日 close が
//               日足SMA より extCap% 超で上なら見送り。
//    セッション・スキップ（任意・既定OFF）: 指定時間帯（既定 9-15、ブローカー時計＝UTC）の
//               ブレイクを見送る。フィックス/指標前の往復ビンタ帯でダマシ・ブレイク失敗が多い
//               時間を外す用途。境界は厳密最適化せず広めのプラトー窓で使うこと。
//
//  no-lookahead: 日足は close[1]/sma[1]（前日確定）+ lookahead_off。extension も同じ前日値。
//  運用上の注意 : 1%リスク上限・実DDはバックテストの1.5-2倍想定。スワップ未計上、終値計算→
//                 次足約定で1本ぶんの誤差。15M チャートに適用すること。
// =============================================================================
strategy("[GOLD 15M] Swing Breakout (ZigZag)",
     overlay                 = true,
     initial_capital         = 10000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     calc_on_every_tick      = false,
     process_orders_on_close = false,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.02)

// ----- inputs ----------------------------------------------------------------
zzK      = input.float(2.0, "ZigZag reversal (ATR)",  step = 0.25, minval = 0.5)
atrLen   = input.int(14,    "ATR length",             minval = 1)
trendLen = input.int(80,    "Trend EMA (gate)",       minval = 1)
useGate  = input.bool(true, "Require wave-1 high above trend EMA")
rr       = input.float(4.0, "Reward : Risk",          step = 0.5, minval = 0.5)
boWindow = input.int(20,    "Breakout window (bars after wave-2 low)", minval = 1)
riskPct  = input.float(1.0, "Risk per trade (% equity)", step = 0.25, minval = 0.0) / 100.0
useDaily = input.bool(true, "Daily SMA regime gate (longs only when daily close > rising SMA)")
dSmaLen  = input.int(150,   "Daily SMA length (regime gate)", minval = 1)
dSlopeK  = input.int(10,    "Daily SMA slope lookback (rising over k days; 0=off)", minval = 0)
useExtCap= input.bool(true, "Extension cap (skip when prior-day close > extCap% above daily SMA)")
extCap   = input.float(8.0, "Extension cap % above daily SMA (skip entries beyond this)", step = 0.5, minval = 0.0)
useKama  = input.bool(false,"Daily KAMA-rising gate (optional alt; default OFF)")
kamaLen  = input.int(14,    "Daily KAMA length", minval = 2)
useSess  = input.bool(false,"Session skip (skip breakouts inside a dead-window hour range; default OFF)")
sessTz   = input.string("UTC", "Session timezone (match the broker-server clock used for validation)")
skipFrom = input.int(9,     "Skip window START hour (inclusive)", minval = 0, maxval = 23)
skipTo   = input.int(15,    "Skip window END hour (exclusive)",   minval = 1, maxval = 24)

atr   = ta.atr(atrLen)
ema80 = ta.ema(close, trendLen)
flat  = strategy.position_size == 0

// Kaufman Adaptive MA (KAMA) -- ER-modulated smoothing (fast=2, slow=30).
f_kama(src, len) =>
    mom = math.abs(src - src[len])
    vol = math.sum(math.abs(src - src[1]), len)
    er  = vol != 0 ? mom / vol : 0.0
    sc  = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float k = na
    k := na(k[1]) ? src : k[1] + sc * (src - k[1])
    k

// daily regime: prior COMPLETED day's close above a RISING daily SMA (no repaint / no lookahead).
dSmaNow  = request.security(syminfo.tickerid, "1D", ta.sma(close, dSmaLen)[1],            lookahead = barmerge.lookahead_off)
dClose1  = request.security(syminfo.tickerid, "1D", close[1],                              lookahead = barmerge.lookahead_off)
dSmaPast = request.security(syminfo.tickerid, "1D", ta.sma(close, dSmaLen)[1 + dSlopeK],   lookahead = barmerge.lookahead_off)
dailyUp = (dClose1 > dSmaNow) and (dSlopeK <= 0 or dSmaNow > dSmaPast)
dailyOk = (not useDaily) or dailyUp

// EXTENSION CAP: prior-day close vs prior-day daily SMA (same no-lookahead values as the gate).
extPct = dSmaNow != 0 ? (dClose1 - dSmaNow) / dSmaNow * 100.0 : 0.0
extOk  = (not useExtCap) or (extPct <= extCap)

// daily KAMA(kamaLen)-rising gate (alt/optional, no repaint / no lookahead).
dKama1 = request.security(syminfo.tickerid, "1D", f_kama(close, kamaLen)[1], lookahead = barmerge.lookahead_off)
dKama2 = request.security(syminfo.tickerid, "1D", f_kama(close, kamaLen)[2], lookahead = barmerge.lookahead_off)
kamaUp = dKama1 > dKama2
kamaOk = (not useKama) or kamaUp

// SESSION SKIP (optional): block entries whose hour is inside [skipFrom, skipTo).
hr      = hour(time, sessTz)
inSkip  = hr >= skipFrom and hr < skipTo
sessOk  = (not useSess) or (not inSkip)

// ----- online ZigZag (ATR-threshold reversal) --------------------------------
var int   zzDir = 1
var float zzExt = na
if na(zzExt)
    zzExt := high

var float swHigh    = na   // H1
var float swLow     = na   // L2
var float swLowPrev = na   // L0

var bool  armed  = false
var float armH1  = na
var float armL2  = na
var int   armBar = na

thr = zzK * atr

if zzDir >= 0
    if high > zzExt
        zzExt := high
    else if zzExt - low >= thr
        swHigh := zzExt
        zzDir  := -1
        zzExt  := low
if zzDir <= 0
    if low < zzExt
        zzExt := low
    else if high - zzExt >= thr
        swLowPrev := swLow
        swLow     := zzExt
        zzDir     := 1
        zzExt     := high
        okStruct = not na(swHigh) and not na(swLowPrev) and swLow > swLowPrev and swHigh > swLowPrev
        okGate   = (not useGate) or (not na(ema80) and swHigh > ema80)
        if okStruct and okGate
            armed  := true
            armH1  := swHigh
            armL2  := swLow
            armBar := bar_index

if armed and (bar_index - armBar) > boWindow
    armed := false

// ----- entry: confirmed close above H1, daily gate + extension cap, risk-sized -
var float curStop = na
var float curTgt  = na
if armed and flat and bar_index > armBar and close > armH1
    if dailyOk and kamaOk and extOk and sessOk
        risk = close - armL2
        if risk > 0
            curStop := armL2
            curTgt  := close + rr * risk
            qty = (strategy.equity * riskPct) / risk
            strategy.entry("L", strategy.long, qty = qty)
    armed := false

if strategy.position_size > 0
    strategy.exit("L-exit", "L", stop = curStop, limit = curTgt)

// ----- plots -----------------------------------------------------------------
plot(useDaily ? dSmaNow : na, "Daily SMA (regime)", color = color.new(color.purple, 0), linewidth = 1)
bgcolor(useDaily and not dailyUp ? color.new(color.red, 92) : na, title = "SMA regime down/flat (gated off)")
bgcolor(useExtCap and not extOk ? color.new(color.yellow, 88) : na, title = "Extension too high (chase gated off)")
bgcolor(useKama and not kamaUp ? color.new(color.orange, 90) : na, title = "Daily KAMA falling (gated off)")
bgcolor(useSess and inSkip ? color.new(color.gray, 88) : na, title = "Session skip window (entries off)")
plot(ema80, "Trend EMA", color = color.new(color.blue, 0), linewidth = 2)
plot(armed ? armH1 : na, "Armed H1 (break line)", color = color.new(color.orange, 0),
     style = plot.style_linebr, linewidth = 1)
plot(armed ? armL2 : na, "Armed L2 (stop)", color = color.new(color.red, 0),
     style = plot.style_linebr, linewidth = 1)
plotshape(armed and flat and bar_index > armBar and close > armH1, title = "Breakout",
     style = shape.triangleup, location = location.belowbar, color = color.lime, size = size.tiny)
