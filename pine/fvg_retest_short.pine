//@version=6
// =============================================================================
// FVG Retest Short — bearish Fair-Value-Gap retest, short-only
// =============================================================================
// LOGIC
//   1. Bearish FVG (3-bar down-displacement gap): high < low[2] and close[1] < low[2].
//      The gap zone is [high (lower edge) .. low[2] (upper edge)], sitting above price
//      as resistance.
//   2. Arm a LIMIT SELL at the chosen edge of the gap (default = the FAR/upper edge,
//      low[2]) — i.e. sell the rally back UP into the gap, in the gap (down) direction.
//   3. The setup is cancelled if the gap is MITIGATED (a close back above the upper edge)
//      or if it is not filled within `maxWait` bars.
//   4. One position at a time (no overlap). On fill: ATR stop above / ATR target below,
//      plus a time stop after `maxHold` bars.
//
// WHY SHORT-ONLY: the long (bullish-FVG) side just re-expresses a trend/breakout the book
//   already holds; the short side is the part that is not already covered. Long is omitted
//   on purpose, not forgotten.
//
// INPUTS / TUNING: validated character on gold & BTC at 2h/4h/8h with the FAR edge. Lower
//   timeframes shred on cost; 1d is too thin. This is a hedge-natured, negatively-correlated
//   sleeve — size it SMALL alongside long exposure, do not run it large standalone.
//
// CAVEATS: short on a trending asset carries squeeze / gap-up tail risk not captured by a
//   fixed ATR stop. CFD short swap/funding is a real recurring cost — set commission/slippage
//   to your broker's actual figures before trusting the equity curve.
// =============================================================================

strategy("FVG Retest Short", overlay = true, pyramiding = 0,
     initial_capital = 10000, commission_type = strategy.commission.percent,
     commission_value = 0.05, slippage = 2, calc_on_order_fills = false)

// ---------------------------------------------------------------- inputs
edgeMode = input.string("Far (gap top)", "Limit fill edge",
     options = ["Near (gap bottom)", "Mid", "Far (gap top)"],
     tooltip = "Where in the gap the limit sell sits. Far = deeper retrace = better price (validated best).")
maxWait  = input.int(50, "Max bars to wait for retest fill", minval = 1)
maxHold  = input.int(30, "Max bars to hold (time stop)", minval = 1)
atrLen   = input.int(14, "ATR length", minval = 1)
slMult   = input.float(2.0, "Stop (× ATR)", minval = 0.1, step = 0.1)
tpMult   = input.float(2.5, "Target (× ATR)", minval = 0.1, step = 0.1)
riskPct  = input.float(1.0, "Risk per trade (% equity)", minval = 0.05, step = 0.05,
     tooltip = "Position is sized so a full ATR stop loses this % of equity — matches the 1%-risk research sizing.")
showZone = input.bool(true, "Show active gap level")

atr = ta.atr(atrLen)

// ---------------------------------------------------------------- bearish FVG
bearFVG = high < low[2] and close[1] < low[2]
gapTop  = low[2]        // upper edge (mitigation reference)
gapBot  = high          // lower edge (this bar's high)
limitLvl = edgeMode == "Near (gap bottom)" ? gapBot
         : edgeMode == "Mid"               ? math.avg(gapBot, gapTop)
         :                                   gapTop

// ---------------------------------------------------------------- pending-order state
var float pendLevel  = na      // working limit price
var float pendTop    = na      // gap upper edge -> mitigation test
var int   pendExpiry = na      // bar_index by which it must fill

flat = strategy.position_size == 0

// (re)arm on a fresh bearish FVG while flat; a newer gap replaces a stale pending one
if bearFVG and flat
    pendLevel  := limitLvl
    pendTop    := gapTop
    pendExpiry := bar_index + maxWait

// cancel if mitigated (close above the gap top) or expired
if not na(pendLevel) and (close > pendTop or bar_index > pendExpiry)
    pendLevel  := na
    pendTop    := na
    pendExpiry := na

// place / maintain the working limit short while flat; otherwise no order.
// size by risk: a full ATR stop (slMult*atr) loses riskPct of equity.
qty = math.ceil((strategy.equity * riskPct / 100.0) / (slMult * atr) * 100) / 100  // 0.01ロット刻みに切り上げ
if not na(pendLevel) and flat and qty > 0
    strategy.entry("Short", strategy.short, qty = qty, limit = pendLevel)
else
    strategy.cancel("Short")

// ---------------------------------------------------------------- on fill: exits
var float entryAtr = na
var int   entryBar = na
justEntered = strategy.position_size < 0 and strategy.position_size[1] == 0
if justEntered
    entryAtr  := atr
    entryBar  := bar_index
    pendLevel := na        // consumed
    pendTop   := na
    pendExpiry := na

if strategy.position_size < 0
    sl = strategy.position_avg_price + slMult * entryAtr
    tp = strategy.position_avg_price - tpMult * entryAtr
    strategy.exit("Exit", from_entry = "Short", stop = sl, limit = tp)
    if bar_index - entryBar >= maxHold
        strategy.close("Short", comment = "time")

// ---------------------------------------------------------------- visuals
plot(showZone and not na(pendLevel) ? pendLevel : na, "Pending short limit",
     color = color.new(color.red, 0), style = plot.style_linebr, linewidth = 2)
plotshape(justEntered, "Entry", shape.triangledown, location.abovebar,
     color.new(color.red, 0), size = size.tiny)
