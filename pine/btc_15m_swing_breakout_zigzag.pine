//@version=5
// =============================================================================
//  [BTC 15M]  Breakout Wave -- Pattern B (3rd-wave) -- ZigZag / RR4.5
//             + 4H-KAMA gate + PULLBACK-LIMIT entry.  15M chart, long-only.
//
//  ロジック（手法B = 第3波ブレイク、押し目指値執行）:
//    波の検出 : オンライン ZigZag（zzK*ATR 逆行で確定、リペイント無し）。
//    骨格     : L0(安)->H1(高=1波天井)->L2(安) で L2>L0（higher low）。H1>80EMA（任意ゲート）。
//    レジーム : KAMA(14)が前バーまで上向き（ER自己適応＝BTCのボラに合う。SMA固定ゲートは不可）。
//               ゲートTF既定=240（4時間足）。D にすると本数が減り滑らかになるがブック審判では劣後。
//               4H側は弱気相場の戻りで騙されやすい（弱気年の出血は構造的で、ゲートでは消せない）。
//    トリガ   : L2 確定後、足が H1 を「終値で」上抜け＋ゲートTFのKAMA上向きなら "武装"。
//    エントリ : 成行で飛び乗らず、ブレイク終値 e・損切 L2・risk=e-L2 に対し
//               lim = e - frac*risk（既定 frac0.3）に指値。押しが lim に来たら約定。
//               来る前に target へ走り抜けたら見送り（＝強ブレイクの取り逃し＝逆選択の税）。
//    玉サイズ : 前日高値(PDH)との位置で二段。ブレイク終値が PDH より上（新値圏＝頭上に
//               前日の売り物が無い）ならフル玉、前日レンジ内なら insideW 倍（既定0.5、
//               0にするとレンジ内は見送り）。レンジ内ブレイクは頭上供給に食われやすい。
//    E1階段  : useStair=on（単独運用向け）で上の二段を三段に置換 -- ブレイク終値が
//               「前日高値 かつ 直近確定4Hスイング高値」の両方の上=フル、片方だけ=0.5、
//               どちらの上でもない=0.25。日足下降カット(useDsma, x0.75)と併用が本体。
//               4Hスイング高値は同じATR-ZigZagを4H足に適用（確定足のみ・リペイント無し）。
//               ※ICTラベルによる弱玉カットは近似検出器のため未移植（意図的）。
//               ブック(6レッグ)では階段/日足は使わない -- PDHソフト0.5のまま（単独運用専用）。
//    固定ロット: useFixed=on で risk% をやめ、強度の段で離散ロットを直接置く（小口座の手張り用）。
//               段=ブレイク終値が{前日高値, 4Hスイング高値}の何本の上か。既定 neither/one/both=
//               0.01/0.02/0.02（＝運用の2段: 濃縮が倍になる neither|one 境界で切る）。both=0.03
//               にすると3段（強い層に厚く張るが濃縮1.3倍への過剰張りで頑健性とDDは劣る）。
//               ※固定ロットでは日足下降カットは適用しない（0.01の床より下に削れないため）。
//    損切/利確: 損切=L2（価格固定）、利確=e+RR*risk（価格固定、既定RR4.5）。指値を下げるぶん
//               実効RRは膨らむ（reward↑/risk↓）。目標を近づけると勝ちを切ることになり劣化する
//               （RR>=4.5 の帯が最良で、RR4.0 は取り逃しが出る）。サイズ: 1トレード=資金 riskPct%
//               （risk=lim-L2）、BTC最小0.01ロット刻みに切り上げ（リスク許容5%内、取りこぼし回避）。
//    ラチェット : 既定OFF。含み益が TP2*u に届いたら損切を TP1*u へ引き上げる（u=lim-L2）任意機能。
//               日足KAMAゲートの下でのみDDを削る。既定の4Hゲートの下では走者を切って損なので使わない。
//
//  no-lookahead: KAMAゲート/PDH は [1]（前バー/前日の確定値）+ lookahead_off。終値計算→次足約定で1本ぶんの誤差。
//  運用上の注意 : long-only。1%リスク上限・実DDはバックテストの1.5-2倍想定。**BTCのスプレッド/
//                 スワップは別途確認**（tight でないが約定コストは要検証）。15M チャートに適用。
//                 出来高フロー（Binanceのテイカー比/上下出来高比）による退出は検証の結果 **不採用**:
//                 効果に見えたものは時刻ずれ由来の先読みだった（docs/findings/s02_exits.md）。
// =============================================================================
strategy("[BTC 15M] Swing Breakout (ZigZag) + pullback-limit",
     overlay                 = true,
     initial_capital         = 10000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 1,
     calc_on_every_tick      = false,
     process_orders_on_close = false,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.03)

// ----- inputs ----------------------------------------------------------------
zzK      = input.float(2.0,  "ZigZag reversal (ATR)", step = 0.25, minval = 0.5)
atrLen   = input.int(14,     "ATR length", minval = 1)
trendLen = input.int(80,     "Trend EMA (gate)", minval = 1)
useGate  = input.bool(true,  "Require wave-1 high above trend EMA")
rr       = input.float(4.5,  "Reward : Risk (fixed target level)", step = 0.5, minval = 0.5)
boWindow = input.int(20,     "Breakout window (bars after wave-2 low)", minval = 1)
riskPct  = input.float(1.0,  "Risk per trade (% equity)", step = 0.25, minval = 0.0) / 100.0
pbFrac   = input.float(0.30, "Pullback-limit depth (entry = e - frac*risk)", step = 0.05, minval = 0.0, maxval = 0.95)
fillWin  = input.int(200,    "Pullback-limit fill window (bars; cancel if unfilled)", minval = 1)
useKama  = input.bool(true,  "KAMA-rising regime gate (BTC's gate)")
kamaTf   = input.timeframe("240", "KAMA gate timeframe (240 = the book's leg; D = slower/fewer trades)")
kamaLen  = input.int(14,     "KAMA length", minval = 2)
usePdh   = input.bool(true,  "PDH sizing (full size only above prior-day high)")
pdhInW   = input.float(0.5,  "Inside-range size multiplier (0 = skip inside-range breaks; set 0 for the STANDALONE leg)", step = 0.25, minval = 0.0, maxval = 1.0)
useStair = input.bool(false, "E1 size STAIRCASE (STANDALONE): full only above BOTH prior-day high AND last 4H swing high; one=0.5, neither=0.25 -- REPLACES the PDH-soft weight above. Pair with the daily-downtrend cut below.")
useDsma  = input.bool(false, "Daily-downtrend size cut (STANDALONE ONLY -- harmful inside the 6-leg book)")
dsmaLen  = input.int(150,    "Daily SMA length for the downtrend test", minval = 20)
dsmaW    = input.float(0.75, "Size multiplier when daily close < its SMA (target is NOT moved)", step = 0.05, minval = 0.0, maxval = 1.0)
useFixed = input.bool(false, "FIXED-LOT mode (STANDALONE hand-trading): ignore risk% and place a discrete lot by strength tier. Tier = how many of {prior-day high, last 4H swing high} the break closes above.", group = "Fixed-lot tiers")
lotNei   = input.float(0.01, "  lot: NEITHER above (weakest)",           step = 0.01, minval = 0.01, group = "Fixed-lot tiers")
lotOne   = input.float(0.02, "  lot: ONE above",                          step = 0.01, minval = 0.01, group = "Fixed-lot tiers")
lotBoth  = input.float(0.02, "  lot: BOTH above (2-tier op = 0.02; set 0.03 for the aggressive 3-tier)", step = 0.01, minval = 0.01, group = "Fixed-lot tiers")
useRatch = input.bool(false, "TP2->TP1 stop ratchet (only helps under the DAILY KAMA gate; harmful under 240)")
tp2Rr    = input.float(3.5,  "Ratchet trigger TP2 (in R of lim-risk)", step = 0.5, minval = 0.5)
ratToRr  = input.float(2.0,  "Ratchet stop-to level TP1 (in R; 0 = breakeven)", step = 0.5, minval = 0.0)
showZZ   = input.bool(true,  "ZigZag: draw the swing line", group = "ZigZag drawing")
zzCol    = input.color(color.new(color.teal, 0), "ZigZag color", group = "ZigZag drawing")
zzW      = input.int(2,      "ZigZag width", minval = 1, group = "ZigZag drawing")

atr   = ta.atr(atrLen)
ema80 = ta.ema(close, trendLen)
flat  = strategy.position_size == 0

// Kaufman Adaptive MA (KAMA) -- ER-modulated smoothing (fast=2, slow=30).
f_kama(src, len) =>
    mom = math.abs(src - src[len])
    vol = math.sum(math.abs(src - src[1]), len)
    er  = vol != 0 ? mom / vol : 0.0
    sc  = math.pow(er * (2.0 / 3.0 - 2.0 / 31.0) + 2.0 / 31.0, 2)
    var float k = na
    k := na(k[1]) ? src : k[1] + sc * (src - k[1])
    k

// KAMA(kamaLen)-rising gate on kamaTf (prior completed bar; no repaint / no lookahead).
dKama1 = request.security(syminfo.tickerid, kamaTf, f_kama(close, kamaLen)[1], lookahead = barmerge.lookahead_off)
dKama2 = request.security(syminfo.tickerid, kamaTf, f_kama(close, kamaLen)[2], lookahead = barmerge.lookahead_off)
kamaUp = dKama1 > dKama2
kamaOk = (not useKama) or kamaUp

// prior-day high (prior COMPLETED day; no repaint / no lookahead)
pdh = request.security(syminfo.tickerid, "1D", high[1], lookahead = barmerge.lookahead_off)

// daily trend state, from the prior COMPLETED daily bar. When the daily close sits below its SMA a
// 15m long is counter-trend: the up-legs run about half as far (median excursion 2.69R -> 1.19R).
// The far target still wins there -- roughly a quarter of them still reach 4.5R and that tail is the
// whole expectancy -- so this cuts the SIZE, never the target.
dSmaUp = request.security(syminfo.tickerid, "1D", close[1] > ta.sma(close, dsmaLen)[1],
                          lookahead = barmerge.lookahead_off)
dsmaOk = (not useDsma) or na(dSmaUp) or dSmaUp ? 1.0 : dsmaW

// ----- E1 component-1: last CONFIRMED 4H swing high --------------------------
// The staircase (useStair) needs the most recent confirmed swing high on the 4H timeframe. We run
// the SAME ATR-ZigZag as the 15m wave below, but stepped once per COMPLETED 4H bar. Fetch the just-
// closed 4H bar (high[1]/low[1] on the 4H series + lookahead_off = no repaint) and advance the state
// only when a new 4H period opens (= the prior 4H bar has just closed). hh4h holds the last swing high.
h4 = request.security(syminfo.tickerid, "240", high[1],           lookahead = barmerge.lookahead_off)
l4 = request.security(syminfo.tickerid, "240", low[1],            lookahead = barmerge.lookahead_off)
a4 = request.security(syminfo.tickerid, "240", ta.atr(atrLen)[1], lookahead = barmerge.lookahead_off)
is4New = ta.change(time("240")) != 0
var int   z4Dir = 1
var float z4Ext = na
var float hh4h  = na
if is4New and not na(a4) and a4 > 0
    if na(z4Ext)
        z4Ext := h4
    thr4 = zzK * a4
    if z4Dir >= 0
        if h4 > z4Ext
            z4Ext := h4
        else if z4Ext - l4 >= thr4
            hh4h  := z4Ext
            z4Dir := -1
            z4Ext := l4
    if z4Dir <= 0
        if l4 < z4Ext
            z4Ext := l4
        else if h4 - z4Ext >= thr4
            z4Dir := 1
            z4Ext := h4

// ----- online ZigZag (ATR-threshold reversal) --------------------------------
var int   zzDir = 1
var float zzExt = na
var int   zzExtBar   = na  // bar_index of the running extreme (for ZigZag drawing)
var int   zzPrevBar  = na  // last confirmed pivot: bar
var float zzPrevPrice = na // last confirmed pivot: price
if na(zzExt)
    zzExt := high
if na(zzExtBar)
    zzExtBar := bar_index

var float swHigh    = na   // H1
var float swLow     = na   // L2
var float swLowPrev = na   // L0

var bool  armed  = false
var float armH1  = na
var float armL2  = na
var int   armBar = na

thr = zzK * atr

if zzDir >= 0
    if high > zzExt
        zzExt := high
    else if zzExt - low >= thr
        swHigh := zzExt
        if showZZ
            if not na(zzPrevBar)
                line.new(zzPrevBar, zzPrevPrice, zzExtBar, swHigh, xloc = xloc.bar_index, color = zzCol, width = zzW)
            zzPrevBar   := zzExtBar
            zzPrevPrice := swHigh
        zzDir  := -1
        zzExt  := low
if zzDir <= 0
    if low < zzExt
        zzExt := low
    else if high - zzExt >= thr
        swLowPrev := swLow
        swLow     := zzExt
        if showZZ
            if not na(zzPrevBar)
                line.new(zzPrevBar, zzPrevPrice, zzExtBar, swLow, xloc = xloc.bar_index, color = zzCol, width = zzW)
            zzPrevBar   := zzExtBar
            zzPrevPrice := swLow
        zzDir     := 1
        zzExt     := high
        okStruct = not na(swHigh) and not na(swLowPrev) and swLow > swLowPrev and swHigh > swLowPrev
        okGate   = (not useGate) or (not na(ema80) and swHigh > ema80)
        if okStruct and okGate
            armed  := true
            armH1  := swHigh
            armL2  := swLow
            armBar := bar_index

// track the bar of the running extreme (for ZigZag drawing; updated after the swing block)
if not na(zzExt[1]) and zzExt != zzExt[1]
    zzExtBar := bar_index

if armed and (bar_index - armBar) > boWindow
    armed := false

// ----- pullback-limit state machine ------------------------------------------
var bool  pend    = false
var float pLim    = na
var float pStop   = na
var float pTgt    = na
var float pU      = na       // realized risk = lim - stop (sizing + ratchet unit)
var float pW      = na       // size weight: 1.0 above PDH (new-high air), pdhInW inside range
var float pLotF   = na       // fixed-lot tier size (used only if useFixed)
var int   pBar    = na
var float curStop = na
var float curTgt  = na
var bool  ratched = false

// place a pullback limit on a confirmed break (do not chase at market)
if armed and flat and not pend and bar_index > armBar and close > armH1 and kamaOk
    e    = close
    risk = e - armL2
    lim  = e - pbFrac * risk
    // size weight: E1 staircase (PDH x 4H-swing-high, 1.0/0.5/0.25) if useStair, else the PDH-soft
    // weight. Either is then scaled by the daily-downtrend cut. (Book = PDH-soft; standalone = staircase.)
    aboveP = not na(pdh) and e > pdh
    aboveH = not na(hh4h) and e > hh4h
    stair  = (aboveP and aboveH) ? 1.0 : (aboveP or aboveH) ? 0.5 : 0.25
    w    = (useStair ? stair : ((not usePdh) or aboveP ? 1.0 : pdhInW)) * dsmaOk
    // fixed-lot tier (used only if useFixed): both/one/neither above {PDH, 4H swing high}.
    // Daily-downtrend cut is NOT applied here (cannot go below the 0.01 floor) -- risk% mode only.
    tierLot = (aboveP and aboveH) ? lotBoth : (aboveP or aboveH) ? lotOne : lotNei
    if risk > 0 and lim > armL2 and w > 0
        pLim  := lim
        pStop := armL2
        pTgt  := e + rr * risk
        pU    := lim - armL2
        pW    := w
        pLotF := tierLot
        pBar  := bar_index
        pend  := true
    armed := false

// while waiting: keep the limit live; cancel if price ran to target first (missed) or expired
if pend and flat
    // FIXED-LOT: place the strength-tier lot directly. Else: risk% sizing (1トレード=資金riskPct%,
    // BTC最小0.01ロット刻みに切り上げ／リスク許容5%内なので取りこぼしを避け最小0.01で建てる)。
    qty = useFixed ? pLotF : math.ceil((strategy.equity * riskPct * pW) / pU * 100) / 100
    if qty >= 0.01
        strategy.entry("L", strategy.long, qty = qty, limit = pLim)
    if high >= pTgt
        strategy.cancel("L")
        pend := false
    else if bar_index - pBar >= fillWin
        strategy.cancel("L")
        pend := false

// on fill: lock the exit levels
if strategy.position_size > 0 and pend
    pend     := false
    curStop  := pStop
    curTgt   := pTgt
    ratched  := false

// stop / target stay live intrabar (they take precedence over the close-based flow exit)
if strategy.position_size > 0
    strategy.exit("L-exit", "L", stop = curStop, limit = curTgt)

// ratchet: once high >= lim + tp2Rr*u, raise the stop to lim + ratToRr*u (effective next bar)
if strategy.position_size > 0 and useRatch and not ratched and high >= pLim + tp2Rr * pU
    curStop := pLim + ratToRr * pU
    ratched := true

// ----- plots -----------------------------------------------------------------
bgcolor(useKama and not kamaUp ? color.new(color.orange, 90) : na, title = "KAMA gate falling (gated off)")
plot(ema80, "Trend EMA", color = color.new(color.blue, 0), linewidth = 2)
plot(armed ? armH1 : na, "Armed H1 (break line)", color = color.new(color.orange, 0),
     style = plot.style_linebr, linewidth = 1)
plot(armed ? armL2 : na, "Armed L2 (stop)", color = color.new(color.red, 0),
     style = plot.style_linebr, linewidth = 1)
plot(pend ? pLim : na, "Pullback limit", color = color.new(color.aqua, 0),
     style = plot.style_linebr, linewidth = 1)
plot(usePdh ? pdh : na, "Prior-day high (PDH)", color = color.new(color.gray, 30),
     style = plot.style_steplinebr, linewidth = 1)
plot(useStair ? hh4h : na, "Last 4H swing high (E1 staircase)", color = color.new(color.purple, 20),
     style = plot.style_steplinebr, linewidth = 1)
brkNow = armed and flat and not pend and bar_index > armBar and close > armH1 and kamaOk
plotshape(brkNow and close > pdh, title = "Break above PDH (full size)",
     style = shape.triangleup, location = location.belowbar, color = color.lime, size = size.tiny)
plotshape(brkNow and not (close > pdh), title = "Break inside range (reduced size)",
     style = shape.triangleup, location = location.belowbar, color = color.yellow, size = size.tiny)
