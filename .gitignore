# --- environment (regenerable) ---
.venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# --- data feeds: large + broker-licensed + regenerable via the mt5-mcp bridge ---
data/

# --- scratch / OS / Windows-WSL cruft ---
scratch/
.DS_Store
*Zone.Identifier*

# --- scratchpad: keep the .py evidence scripts (cited by docs/verified_findings.md),
#     ignore run outputs / images / cached data (regenerable by re-running) ---
scratchpad/*.txt
scratchpad/*.out
scratchpad/*.err
scratchpad/*.csv
scratchpad/*.png
scratchpad/*.json

# --- local-only config (never publish secrets) ---
*.env
.env
secrets.*
config.local.*

# --- local Claude Code config (machine-local; never publish) ---
# exception: skills/ and agents/ are part of the research workflow -> tracked
.claude/*
!.claude/skills/
!.claude/agents/
scratchpad/**/*.csv
scratchpad/*.log
